{
  "name": "nrcs-frontend",
  "version": "1.0.0",
  "description": "NRCS Blockchain Platform - Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "format": "prettier --write \"**/*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts,json,md,scss,css,html}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{vue,js,jsx,cjs,mjs,ts,tsx,cts,mts,json,md,scss,css,html}\" --ignore-path .gitignore",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "vue": "^3.4.38",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.4",
    "element-plus": "^2.8.6",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.8",
    "vue-i18n": "^9.14.1",
    "echarts": "^5.5.1",
    "vue-echarts": "^7.0.3",
    "dayjs": "^1.11.13",
    "clsx": "^2.1.1",
    "qr-code": "^2.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "prettier": "^3.3.3",
    "typescript": "~5.6.3",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10",
    "vitest": "^2.1.6",
    "@vue/test-utils": "^2.4.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "vue3",
    "blockchain",
    "nrcs",
    "vite",
    "typescript",
    "pinia"
  ],
  "author": "NRCS Team",
  "license": "MIT"
}

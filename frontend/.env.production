# 生产环境前端配置
# 这些值在构建时会被嵌入

# API 配置
VITE_API_BASE_URL=https://api.nrcs.blockchain
VITE_API_TIMEOUT=30000
VITE_WEBSOCKET_URL=wss://ws.nrcs.blockchain

# 应用元数据
VITE_APP_TITLE=NRCS Blockchain
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Neo Rapid Blockchain Ecosystem

# 功能开关
VITE_ENABLE_SMART_CONTRACTS=true
VITE_ENABLE_ASSET_ISSUANCE=true
VITE_ENABLE_LEASING=true
VITE_ENABLE_NODE_MONITORING=true
VITE_ENABLE_CHART=true

# 区块链参数
VITE_CHAIN_SYMBOL=NRC
VITE_CHAIN_DECIMALS=8
VITE_CHAIN_NAME=NRCS Mainnet
VITE_CHAIN_EXPLORER_URL=https://explorer.nrcs.blockchain

# 第三方集成
VITE_WALLET_PROVIDERS=metamask,walletconnect
VITE_FAUCET_ENABLED=false

# 安全配置
VITE_CONTENT_SECURITY_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"

# 性能监控
VITE_SENTRY_DSN=
VITE_GA_TRACKING_ID=

# 多语言支持
VITE_DEFAULT_LOCALE=zh-CN
VITE_SUPPORTED_LOCALES=zh-CN,en
# Database Configuration (WSL native)
DATABASE_URL=postgres://nrcs_user:nrcs_password@localhost:5432/nrcs_db

# Optional: Redis (if installed in WSL)
# REDIS_URL=redis://127.0.0.1:6379

# API Configuration
NRCS_HOST=0.0.0.0
NRCS_PORT=8080
NRCS_WS_PORT=8081

# Logging
RUST_LOG=debug
RUST_BACKTRACE=1
